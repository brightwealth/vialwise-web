# --- TestFlight beta link ---
# Drop the public TestFlight URL here when the beta is open.
# Falls back to in-page anchor when unset.
NEXT_PUBLIC_TESTFLIGHT_URL=

# --- ConvertKit (Kit) email capture ---
# Get these from https://app.kit.com/account_settings/advanced_settings
# When unset, the /api/subscribe route logs to the server console (dev mode).
CONVERTKIT_API_KEY=
CONVERTKIT_FORM_ID=
