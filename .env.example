# --- TestFlight beta link ---
# Drop the public TestFlight URL here when the beta is open.
# Falls back to in-page anchor when unset.
NEXT_PUBLIC_TESTFLIGHT_URL=

# --- App Store launch gate ---
# Controls whether the official "Download on the App Store" badge renders
# (hero primary CTA, header nav, footer). Default OFF so we never ship a dead
# store link before the app is live. Flip to "true" in Vercel's PRODUCTION env
# at the moment of App Store release (then redeploy). Accepts "true" or "1".
NEXT_PUBLIC_APP_LIVE=

# --- ConvertKit (Kit) email capture ---
# Get these from https://app.kit.com/account_settings/advanced_settings
# When unset, the /api/subscribe route logs to the server console (dev mode).
CONVERTKIT_API_KEY=
CONVERTKIT_FORM_ID=
